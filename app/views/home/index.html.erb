<% content_for :title, "Dashboard" %>

<div class="dashboard-wrapper">

  <!-- Page Header -->
  <div class="page-header">
    <h1>Pipeline Dashboard</h1>
    <p>Monitor your tasks, pipelines, and system status at a glance.</p>
  </div>

  <!-- Stat Cards -->
  <div class="stat-cards">
    <div class="stat-card purple">
      <div class="stat-label">Total Todos</div>
      <div class="stat-value"><%= @total_todos %></div>
      <div class="stat-sub">All tracked items</div>
    </div>
    <div class="stat-card green">
      <div class="stat-label">Completed</div>
      <div class="stat-value"><%= @done_todos %></div>
      <div class="stat-sub">Finished tasks</div>
    </div>
    <div class="stat-card amber">
      <div class="stat-label">Pending</div>
      <div class="stat-value"><%= @pending_todos %></div>
      <div class="stat-sub">Still in progress</div>
    </div>
    <div class="stat-card blue">
      <div class="stat-label">Completion</div>
      <div class="stat-value"><%= @completion_pct %>%</div>
      <div class="stat-sub">Overall progress</div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="quick-actions">
    <%= link_to todos_path, class: "action-btn" do %>
      <span class="action-icon icon-purple">&#128203;</span>
      View All Todos
    <% end %>
    <%= link_to new_todo_path, class: "action-btn" do %>
      <span class="action-icon icon-green">&#43;</span>
      New Todo
    <% end %>
    <a href="#overview" class="action-btn">
      <span class="action-icon icon-blue">&#128202;</span>
      Analytics
    </a>
    <a href="#status" class="action-btn">
      <span class="action-icon icon-amber">&#9881;</span>
      System Status
    </a>
  </div>

  <!-- Content Grid -->
  <div class="content-grid" id="overview">

    <!-- Recent Todos -->
    <div class="card">
      <div class="card-header">
        <h2>Recent Todos</h2>
        <%= link_to "View all", todos_path, class: "card-action" %>
      </div>
      <div class="card-body">
        <% if @recent_todos.any? %>
          <ul class="todo-list">
            <% @recent_todos.each do |todo| %>
              <li class="todo-item">
                <span class="todo-check <%= todo.done? ? 'done' : '' %>">
                  <%= todo.done? ? '&#10003;' : '' %>
                </span>
                <span class="todo-title <%= todo.done? ? 'done' : '' %>">
                  <%= link_to todo.title.presence || '(untitled)', todo, style: "color: inherit; text-decoration: none;" %>
                </span>
                <span class="todo-badge <%= todo.done? ? 'badge-done' : 'badge-pending' %>">
                  <%= todo.done? ? 'Done' : 'Pending' %>
                </span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p style="color: var(--text-muted); font-size: 0.9rem; padding: 1rem 0;">
            No todos yet. <%= link_to "Create your first one", new_todo_path, style: "color: var(--primary);" %>.
          </p>
        <% end %>
      </div>
    </div>

    <!-- Side Panel -->
    <div style="display: flex; flex-direction: column; gap: 1.25rem;">

      <!-- Progress -->
      <div class="card">
        <div class="card-header">
          <h2>Progress</h2>
        </div>
        <div class="card-body">
          <div class="progress-section">
            <div class="progress-label">
              <span>Task Completion</span>
              <span><%= @completion_pct %>%</span>
            </div>
            <div class="progress-track">
              <div class="progress-fill fill-purple" style="width: <%= @completion_pct %>%;"></div>
            </div>

            <div class="progress-label">
              <span>Done</span>
              <span><%= @done_todos %> / <%= @total_todos %></span>
            </div>
            <div class="progress-track">
              <div class="progress-fill fill-green" style="width: <%= @total_todos > 0 ? ((@done_todos.to_f / @total_todos) * 100).round : 0 %>%;"></div>
            </div>

            <div class="progress-label">
              <span>Pending</span>
              <span><%= @pending_todos %> / <%= @total_todos %></span>
            </div>
            <div class="progress-track">
              <div class="progress-fill fill-blue" style="width: <%= @total_todos > 0 ? ((@pending_todos.to_f / @total_todos) * 100).round : 0 %>%;"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- System Status -->
      <div class="card" id="status">
        <div class="card-header">
          <h2>System Status</h2>
        </div>
        <div class="card-body">
          <div class="status-row">
            <span class="status-name">Database</span>
            <span class="status-pill pill-green">Operational</span>
          </div>
          <div class="status-row">
            <span class="status-name">Web Server</span>
            <span class="status-pill pill-green">Online</span>
          </div>
          <div class="status-row">
            <span class="status-name">Pipeline</span>
            <span class="status-pill pill-blue">Running</span>
          </div>
          <div class="status-row">
            <span class="status-name">Cache</span>
            <span class="status-pill pill-amber">Warming</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Activity Feed -->
  <div class="card">
    <div class="card-header">
      <h2>Pipeline Activity</h2>
    </div>
    <div class="card-body">
      <ul class="activity-list">
        <li class="activity-item">
          <span class="activity-dot dot-green"></span>
          <span class="activity-text">Deployment pipeline completed successfully</span>
          <span class="activity-time">just now</span>
        </li>
        <li class="activity-item">
          <span class="activity-dot dot-blue"></span>
          <span class="activity-text">Build #42 triggered on branch <strong>main</strong></span>
          <span class="activity-time">2 min ago</span>
        </li>
        <li class="activity-item">
          <span class="activity-dot dot-purple"></span>
          <span class="activity-text">Container image pushed to registry</span>
          <span class="activity-time">5 min ago</span>
        </li>
        <li class="activity-item">
          <span class="activity-dot dot-amber"></span>
          <span class="activity-text">Health check threshold reached — auto-scaling triggered</span>
          <span class="activity-time">12 min ago</span>
        </li>
        <li class="activity-item">
          <span class="activity-dot dot-green"></span>
          <span class="activity-text">Namespace <strong>hello-pipelines</strong> provisioned</span>
          <span class="activity-time">1 hr ago</span>
        </li>
      </ul>
    </div>
  </div>

</div>
