<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? "#{yield :title} — Hello Pipelines" : "Hello Pipelines" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar">
      <a href="/" class="navbar-brand">
        <span class="brand-icon">&#9654;</span>
        Hello Pipelines
      </a>
      <ul class="navbar-nav">
        <li><a href="/" class="<%= controller_name == 'home' ? 'active' : '' %>">Dashboard</a></li>
        <li><a href="/todos" class="<%= controller_name == 'todos' ? 'active' : '' %>">Todos</a></li>
      </ul>
    </nav>

    <%= yield %>

    <footer class="dashboard-footer">
      Hello Pipelines &mdash; Feature 6
    </footer>
  </body>
</html>
