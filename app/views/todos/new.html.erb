<% content_for :title, "New Todo" %>

<div class="todos-page">
  <div class="page-header" style="margin-bottom: 1.5rem;">
    <h1 style="font-size:1.6rem; font-weight:700; color: var(--text);">New Todo</h1>
    <p style="color: var(--text-muted); font-size:0.9rem; margin-top:0.2rem;">Add a new task to track</p>
  </div>

  <%= render "form", todo: @todo %>
</div>
