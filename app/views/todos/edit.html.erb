<% content_for :title, "Edit Todo" %>

<div class="todos-page">
  <div class="page-header" style="margin-bottom: 1.5rem;">
    <h1 style="font-size:1.6rem; font-weight:700; color: var(--text);">Edit Todo</h1>
    <p style="color: var(--text-muted); font-size:0.9rem; margin-top:0.2rem;"><%= @todo.title.presence || 'Untitled' %></p>
  </div>

  <%= render "form", todo: @todo %>
</div>
