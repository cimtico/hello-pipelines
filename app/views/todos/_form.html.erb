<%= form_with(model: todo) do |form| %>
  <% if todo.errors.any? %>
    <div class="alert">
      <strong><%= pluralize(todo.errors.count, "error") %> prevented saving:</strong>
      <ul style="margin: 0.4rem 0 0 1.2rem;">
        <% todo.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-card">
    <div class="form-group">
      <%= form.label :title, class: "form-label" %>
      <%= form.text_field :title, class: "form-input", placeholder: "What needs to be done?" %>
    </div>

    <div class="form-group">
      <%= form.label :description, class: "form-label" %>
      <%= form.text_field :description, class: "form-input", placeholder: "Optional details..." %>
    </div>

    <div class="form-group">
      <label class="form-check">
        <%= form.check_box :done %>
        <span class="form-check-label">Mark as done</span>
      </label>
    </div>

    <div class="form-actions">
      <%= form.submit class: "btn btn-primary" %>
      <%= link_to "Cancel", todos_path, class: "btn btn-ghost" %>
    </div>
  </div>
<% end %>
